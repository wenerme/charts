{
  "name": "charts",
  "version": "1.0.0",
  "description": "Helm chart mirror automation",
  "type": "module",
  "scripts": {
    "mirrorer": "bun run ./cmd/mirrorer/main.ts",
    "sync": "bun run ./cmd/mirrorer/main.ts sync",
    "doctor": "bun run ./cmd/mirrorer/main.ts doctor",
    "manifest": "bun run ./cmd/mirrorer/main.ts manifest",
    "commit:sync": "bun run ./cmd/mirrorer/main.ts commit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "13.0.0",
    "dayjs": "1.11.13",
    "execa": "9.5.2",
    "fs-extra": "11.2.0",
    "lodash": "4.17.21",
    "semver": "7.6.3",
    "yaml": "2.7.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/fs-extra": "11.0.4",
    "@types/lodash": "4.17.14",
    "@types/node": "22.10.5",
    "@types/semver": "7.5.8",
    "prettier": "3.4.2",
    "typescript": "5.7.3"
  }
}
